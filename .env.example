# SMTP — credenciales para enviar correos desde el formulario de contacto
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ivan@ironslash.com
SMTP_PASS=tu_contraseña_o_app_password

# Destinatario y remitente del formulario
CONTACT_TO=ivan@ironslash.com
CONTACT_FROM=ivan@ironslash.com

# Orígenes permitidos para CORS (separados por coma)
ALLOWED_ORIGINS=https://ironslash.com,https://www.ironslash.com

# Puerto del API (default 3921)
PORT=3921
